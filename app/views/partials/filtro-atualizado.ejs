<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="css/filtro.css">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="slide.js"></script>
    
    <title> Modelo App Node </title>
</head>

<body>
    <script src="js/double-slider.js"></script>
    <script src="js/slide.js"></script>

    <!-- Barra de pesquisa -->

    <!-- <section class="search-bar">
        <input type="text" id="nome-escola-search" name="nome-escola-search" placeholder="Nome da Escola">
        <select name="UF" id="regiao-search">
            <ul>
                <option value="regiao"> Região </option>
                <option value="RNO"> Região Norte</option>
                <option value="RND"> Região Nordeste </option>
