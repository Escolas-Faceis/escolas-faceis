    <section id="filtro">
    <h4 id="filtros"  name="filtros">Filtros</h4>

<section class="filter-schools" id="panel">
    <!--   <input type="checkbox" name="z" id="z"><label for="z"></label>    -->

    <section id="escolaridade" class="sec">

        <!-- educação infantil -> edu-inf
             ensino fundamental I -> fund1
             ensino fundamental II -> fund2
             ensino médio -> e-med
             ensino integrado -> e-int
             cursos técnicos -> e-tec
             cursos extracurriculares -> cursos 
             bolsa de estudos -> bes -->

        <h4 id="niveis-de-ensino"> Níveis de Ensino</h4>
        <ul>
        <li><input type="checkbox" name="edu-inf" id="edu-inf"><label for="edu-inf">Educação Infantil</label></li>
        <li><input type="checkbox" name="fund1" id="fund1"><label for="fund1">Ensino Fundamental I</label></li>
        <li><input type="checkbox" name="fund2" id="fund2"><label for="fund2">Ensino Fundamental II</label></li>
        <li><input type="checkbox" name="e-med" id="e-med"><label for="e-med">Ensino Médio</label></li>
        <li><input type="checkbox" name="e-int" id="e-int"><label for="e-int">Ensino Integrado</label></li>
        <li><input type="checkbox" name="e-tec" id="e-tec"><label for="e-tec">Cursos Técnicos</label></li>
        <li><input type="checkbox" name="cursos" id="cursos"><label for="cursos">Cursos Extracurriculares</label></li>
        </ul>
        </section>

    <section id="rede" class="sec">
        <h4 id="rede-escolar"> Rede</h4>
        <ul>
        <li><input type="checkbox" name="municipal" id="municipal"><label for="municipal">Municipal</label></li>
        <li><input type="checkbox" name="estadual" id="estadual"><label for="estadual">Estadual</label></li>
        <li><input type="checkbox" name="fundacao" id="fundacao"><label for="fundacao">Fundação/Instituto</label></li>
        <li><input type="checkbox" name="privada" id="privada"><label for="privada">Privada</label></li>
            <ul>
                
                    
                <section class="range-slider"><h4 id="mens">Mensalidade</h6>
                    <span class="range-input">
                        
                        <section class="range-price">      
                            <label for="min">Min</label>
                            <input type="number" name="min" value="300"> <br>      
                            <label for="max">Max</label>
                            <input type="number" name="max" value="700">      
                          </section>
                      
                    
                    <input type="checkbox" name="bes" id="bes"><label for="bes">Bolsa de Estudos</label>
                </section>
                
            </ul>
        </ul>
    </section>

    <section id="periodo" class="sec">
        <h4 id="turno"> Turno</h4>
        <ul>
        <li><input type="checkbox" name="manha" id="manha"><label for="manha">Manhã</label></li>
        <li><input type="checkbox" name="tarde" id="tarde"><label for="tarde">Tarde</label></li>
        <li><input type="checkbox" name="integral" id="integral"><label for="integral"> Integral</label></li>
        <li><input type="checkbox" name="noite" id="noite"><label for="noite">Noturno</label></li>
        </ul>
    </section>

    <section id="outro" class="sec">
        <h4 id="outros">Outros</h4>
        <ul>
        <li><input type="checkbox" name="ace" id="ace"><label for="ace">Acessibilidade</label></li>
        <li><input type="checkbox" name="eja" id="eja"><label for="eja">EJA</label></li>
        <li><input type="checkbox" name="bilingue" id="bilingue"><label for="bilingue">Escola Bilingue</label></li>
        </ul>
    </section>

    <p><button type="submit" id="filtrar"> Filtrar </button></p>

</section></section>


</body>

</html>