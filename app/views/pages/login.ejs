<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title> Login</title>
    <link rel="stylesheet" href="css/login.css">
</head>

<body>
    <%
    let  erroValidacao =  {"email":"", "password":"" };
    let  msgErro =  {"email":"", "password":"" };
    if(erros) {
        erros.errors.forEach(function(erro) {
            if (erro.path == "email") {
                erroValidacao.email = "erro",
                msgErro.email = erro.msg
            }
            if (erro.path == "password") {
                erroValidacao.password = "erro",
                msgErro.password = erro.msg
            }
        })
    }; %>

    <%- include('../partials/navbar'); %>

    <body>
        <section id="centralizar">
        <main id="form_space">

            <section id="form">
                <form action="/login_post" method="POST">
                    <p>Email</p>
                    <input type="text" id="email" name="email" id="email" value="<%= valores.email %>" class="<%= erroValidacao.email%>">
                    <span class="spanerro"><%=msgErro.email%></span>
                    <p>Senha</p>
                    <input type="text" id="password" name="password" id="password" value="<%= valores.password %>" class="<%= erroValidacao.password%>">    
                    <span class="spanerro"><%=msgErro.password%></span>
                    <div>
                    <input type="checkbox" id="conectado">
                    <label for="conectado">Desejo me manter conectado</label>
                    <p><a href="#">Esqueci minha senha</a></p>
                    </div>
                
                <section id="login2">
                <input type="submit" id="login_button" value="LOGIN" />
                </section>

                <section id="centralizar">
                <p>Não tem uma conta? <a id="laranjinha" href="/cadastro-usuario">Cadastre-se</a></p>
                </section>
                </form>
            </section>

            <section id="texto_lateral">
                <h3>Com o login você pode:</h3>
                <p>✓ Interagir com postagens;</p>
                <p>✓ Se inscrever para testes de admissão;</p>
                <p>✓ Marcar presença em eventos;</p>
                <p>Entre outros!</p>

                <img src="imagem/login_image.png">
            </section>
        </main> 
        </section>

</body>

</body>
<%- include('../partials/footer'); %>
</html>
